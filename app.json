{
  "expo": {
    "name": "OrbitaVerde",
    "slug": "orbita-verde-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "orbitaverde",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "br.com.fiap.orbitaverde"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A1628"
      },
      "package": "br.com.fiap.orbitaverde",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "O OrbitaVerde usa sua localização para registrar coordenadas GPS nos alertas ambientais."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
